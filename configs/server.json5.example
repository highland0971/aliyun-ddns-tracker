{
  // 服务端配置文件示例
  // 复制为 /etc/ddns-heartbeat/server.json5 并修改
  
  // SSL 证书路径（Let's Encrypt）
  "cert_file": "/etc/letsencrypt/live/ddns.haoyuanee.com/fullchain.pem",
  "key_file": "/etc/letsencrypt/live/ddns.haoyuanee.com/privkey.pem",
  
  // 监听端口
  "port": 8443,
  
  // 域名:APIKey 映射（一个域名一个 APIKey）
  "domains": {
    "hyee-ar6121s.haoyuanee.com": "your-api-key-here"
  },
  
  // 阿里云 DNS API 凭证（从环境变量读取优先）
  // "aliyun_access_key_id": "LTAI5t...",
  // "aliyun_access_key_secret": "..."
}
